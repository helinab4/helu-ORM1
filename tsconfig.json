{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "node",
    "allowImportingTsExtensions": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "skipLibCheck": true,
    "strict": false,
    "outDir": "dist",
    "resolveJsonModule": true,
    "lib": ["ES2022", "DOM"],
    "types": ["bun"]
  },
  "include": ["src"]
}
